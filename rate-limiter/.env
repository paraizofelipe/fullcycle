REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Maximum requests per second from a single IP
IP_RATE_LIMIT=10

# Maximum requests per second for a token (default, if not overridden per-token)
TOKEN_RATE_LIMIT=100

# How long (in seconds) a blocked IP/token remains blocked
BLOCK_DURATION_SECONDS=300

# Per-token rate limit overrides: comma-separated "token:limit" pairs
# Example: TOKENS=abc123:200,xyz789:50
TOKENS=
